      badgeData[n-1].earned=true;
      const icon=document.getElementById('badgeIcon'+n);
      if(icon) icon.classList.add('earned');
      const btn=document.getElementById('badgeBtn'+n);
      if(btn){ btn.disabled=true; btn.textContent='✦ Badge Earned'; }
      const msg=document.getElementById('badgeMsg'+n);
      if(msg) msg.classList.add('show');
      const fb=document.getElementById('fb'+n);
      if(fb) fb.classList.add('earned');
    }
  });
 
  // Restore reflections
  ['ref1','ref2','ref3','ref4'].forEach((id,i)=>{
    const val=localStorage.getItem(id);
    const el=document.getElementById(id);
    if(el && val){ el.value=val; updateCharCount(id,'cc'+(i+1)); }
  });
 
  // Build quizzes
  [1,2,3,4].forEach(buildQuiz);
 
  updateMastery();
});
