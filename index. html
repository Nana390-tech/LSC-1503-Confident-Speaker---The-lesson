  const wrap = document.getElementById('quiz' + mod);
  if (!wrap) return;
  const data = quizData[mod];
  const st = quizState[mod];
 
  const dotsHtml = data.map((_,i) => `<div class="q-dot${i===st.q?' active':''}" id="qd${mod}_${i}"></div>`).join('');
 
  if (st.done) {
    const pct = Math.round(st.score/data.length*100);
    const color = pct===100?'#2d7a4f':pct>=67?'#c9973a':'#c0303f';
    const msgs = ['Keep reviewing this module and try again!','Good work — review the explanations above.','Great score! You are ready to move on.','Perfect! You have mastered this module.'];
    const msgIdx = pct===100?3:pct>=67?2:pct>=33?1:0;
    wrap.innerHTML = `<div class="quiz-result"><div style="font-size:0.65rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--crimson);margin-bottom:0.5rem;">Quiz Complete</div><div class="result-score" style="color:${color}">${pct}%</div><div class="result-label">${st.score} / ${data.length} correct</div><div class="result-msg">${msgs[msgIdx]}</div><button class="btn-quiz-next show" style="margin-top:1.25rem;" onclick="resetQuiz(${mod})">↺ Retry Quiz</button></div>`;
    return;
  }
 
  const q = data[st.q];
  const letters = ['A','B','C','D'];
  const optsHtml = q.opts.map((o,i)=>`<div class="q-opt" id="qo${mod}_${i}" onclick="selectAnswer(${mod},${i})"><div class="q-opt-letter">${letters[i]}</div><span>${o}</span></div>`).join('');
 
  wrap.innerHTML = `
    <div class="quiz-header">
      <span class="quiz-tag">Knowledge Check · Module 0${mod}</span>
      <div class="quiz-progress-dots">${dotsHtml}</div>
    </div>
    <div class="quiz-q">Q${st.q+1}. ${q.q}</div>
    <div class="quiz-options">${optsHtml}</div>
    <div class="quiz-feedback" id="qfb${mod}"></div>
    <div class="quiz-nav">
      <span class="quiz-score">Score: ${st.score}/${st.q}</span>
      <button class="btn-quiz-next" id="qnext${mod}" onclick="nextQuestion(${mod})">Next →</button>
    </div>`;
}
 
function selectAnswer(mod, idx) {
  const st = quizState[mod];
  const data = quizData[mod];
  const q = data[st.q];
  const opts = document.querySelectorAll(`[id^="qo${mod}_"]`);
  opts.forEach(o => { o.classList.add('disabled'); });
  const chosen = document.getElementById(`qo${mod}_${idx}`);
  const correct = document.getElementById(`qo${mod}_${q.ans}`);
  const fb = document.getElementById(`qfb${mod}`);
  if (idx === q.ans) {
    chosen.classList.add('correct');
    st.score++;
    fb.className = 'quiz-feedback show correct';
    fb.textContent = '✓ ' + q.exp;
  } else {
    chosen.classList.add('wrong');
    correct.classList.add('correct');
    fb.className = 'quiz-feedback show wrong';
    fb.textContent = '✗ Not quite. ' + q.exp;
  }
  const nextBtn = document.getElementById(`qnext${mod}`);
  if (nextBtn) nextBtn.classList.add('show');
}
 
function nextQuestion(mod) {
  const st = quizState[mod];
  const data = quizData[mod];
  st.q++;
  if (st.q >= data.length) { st.done = true; updateMastery(); }
  buildQuiz(mod);
}
 
function resetQuiz(mod) {
  quizState[mod] = {q:0,score:0,done:false};
  buildQuiz(mod);
}
 
