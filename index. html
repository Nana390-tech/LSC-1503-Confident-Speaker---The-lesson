/* ══════════════════════════════════════════════════════════
   MASTERY
══════════════════════════════════════════════════════════ */
function updateMastery() {
  let score = 0;
  const total = 16;
  [1,2,3,4].forEach(m => {
    if (quizState[m].done) score += 2;
    if (badgeData[m-1].earned) score += 2;
  });
  const pct = Math.round(score/total*100);
  document.getElementById('masteryVal').textContent = pct + '%';
  document.getElementById('progressFill').style.width = pct + '%';
}
 
/* ══════════════════════════════════════════════════════════
   BREATHING EXERCISE 1 (Box Breathing)
══════════════════════════════════════════════════════════ */
let breath1Active = false, breath1Interval = null, breath1Cycles = 0;
const phases1 = [
  {name:'Inhale',sec:4,cls:'inhale',color:'#c0303f'},
  {name:'Hold',sec:4,cls:'hold',color:'#c9973a'},
  {name:'Exhale',sec:4,cls:'exhale',color:'#2d7a4f'},
  {name:'Hold',sec:4,cls:'hold2',color:'#555'}
];
let ph1=0, ct1=4;
 
function toggleBreathing1() {
  if (breath1Active) { pauseBreathing1(); }
  else { startBreathing1(); }
}
 
function startBreathing1() {
  breath1Active = true;
  document.getElementById('breathBtn1').textContent = '⏸ Pause';
  runBreath1Step();
}
 
function pauseBreathing1() {
  breath1Active = false;
  clearTimeout(breath1Interval);
  document.getElementById('breathBtn1').textContent = '▶ Resume';
}
 
function runBreath1Step() {
  if (!breath1Active) return;
  const p = phases1[ph1];
  const ring = document.getElementById('breathRing1');
  ring.className = 'breath-ring ' + p.cls;
  document.getElementById('bPhase1').textContent = p.name;
  document.getElementById('bCount1').textContent = ct1;
  ct1--;
  if (ct1 < 0) {
    ph1 = (ph1+1) % phases1.length;
    ct1 = phases1[ph1].sec;
    if (ph1 === 0) {
      breath1Cycles++;
      document.getElementById('breathCycles1').textContent = 'Cycles: ' + breath1Cycles + ' / 3';
      if (breath1Cycles >= 3) { finishBreath1(); return; }
    }
  }
  breath1Interval = setTimeout(runBreath1Step, 1000);
}
 
function finishBreath1() {
  breath1Active = false;
  const ring = document.getElementById('breathRing1');
  ring.className = 'breath-ring';
  document.getElementById('bPhase1').textContent = 'Done ✓';
  document.getElementById('bCount1').textContent = '✓';
  document.getElementById('bTimer1').textContent = '3 cycles complete!';
  document.getElementById('breathBtn1').textContent = '▶ Restart';
  document.getElementById('breathCycles1').textContent = 'Cycles: 3 / 3 ✓';
  breath1Cycles = 0; ph1 = 0; ct1 = 4;
}
 
function resetBreathing1() {
  clearTimeout(breath1Interval);
  breath1Active = false; breath1Cycles = 0; ph1 = 0; ct1 = 4;
  const ring = document.getElementById('breathRing1');
  ring.className = 'breath-ring';
  document.getElementById('bPhase1').textContent = 'Ready';
  document.getElementById('bCount1').textContent = '—';
  document.getElementById('bTimer1').textContent = 'Press Start';
  document.getElementById('breathBtn1').textContent = '▶ Start';
  document.getElementById('breathCycles1').textContent = 'Cycles: 0 / 3';
}
 
/* ══════════════════════════════════════════════════════════
   3-PACE DRILL
══════════════════════════════════════════════════════════ */
let paceTimer=null, paceRunning=false, pacePhase=0;
const paceLabels=['As fast as you can!','Painfully slow — feel every word','With emphasis — make it land'];
const paceSecs=[25,60,40];
const paceDone=[false,false,false];
let currentPaceSec=0;
 
function startPace(phase) {
  clearInterval(paceTimer);
  pacePhase = phase;
  currentPaceSec = paceSecs[phase-1];
  document.getElementById('paceDisplay').textContent = formatTime(currentPaceSec);
  document.getElementById('pacePhaseLabel').textContent = paceLabels[phase-1];
  [1,2,3].forEach(i=>{
    const el=document.getElementById('pp'+i);
    el.className='pace-phase-btn'+(paceDone[i-1]?' done':'')+(i===phase?' active':'');
  });
  paceRunning=true;
  paceTimer = setInterval(()=>{
    currentPaceSec--;
    document.getElementById('paceDisplay').textContent = formatTime(currentPaceSec);
    if(currentPaceSec<=0){
      clearInterval(paceTimer); paceRunning=false;
      paceDone[phase-1]=true;
      document.getElementById('pp'+phase).className='pace-phase-btn done';
      document.getElementById('pacePhaseLabel').textContent='Phase '+ phase+' complete! ✓';
    }
  },1000);
}
 
function resetPace(){
  clearInterval(paceTimer); paceRunning=false;
  [0,1,2].forEach(i=>paceDone[i]=false);
  document.getElementById('paceDisplay').textContent='00:30';
  document.getElementById('pacePhaseLabel').textContent='Select a phase to begin';
  [1,2,3].forEach(i=>document.getElementById('pp'+i).className='pace-phase-btn');
}
 
function formatTime(s){ return String(Math.floor(s/60)).padStart(2,'0')+':'+String(s%60).padStart(2,'0'); }
 
