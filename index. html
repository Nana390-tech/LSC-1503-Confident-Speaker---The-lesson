<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LSC 1503 · The Confident Speaker</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600;1,700&family=Crimson+Pro:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
/* ── ROOT VARIABLES ───────────────────────────── */
:root {
  --navy: #0d1b2a;
  --navy-mid: #1a2e42;
  --crimson: #c0303f;
  --crimson-light: #e05566;
  --rose: #f7e8ea;
  --rose-mid: #f2d0d5;
  --cream: #fdf9f6;
  --cream-dark: #f5ede8;
  --text: #1c2b3a;
  --text-light: #5a6a7a;
  --white: #ffffff;
  --gold: #c9973a;
  --green: #2d7a4f;
  --shadow: 0 4px 24px rgba(13,27,42,0.10);
  --shadow-lg: 0 12px 48px rgba(13,27,42,0.15);
  --border: rgba(13,27,42,0.08);
}
 
/* ── RESET ───────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  font-family: 'DM Sans', sans-serif;
  background: var(--cream);
  color: var(--text);
  min-height: 100vh;
  overflow-x: hidden;
}
 
/* ── HEADER ──────────────────────────────────── */
.header {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  background: var(--navy);
  padding: 0 2rem;
  height: 60px;
  display: flex; align-items: center; justify-content: space-between;
  box-shadow: 0 2px 20px rgba(0,0,0,0.25);
}
.header-brand { display: flex; align-items: center; gap: 1rem; }
.header-code {
  font-family: 'Playfair Display', serif;
  font-style: italic;
  font-size: 1.1rem;
  color: var(--white);
  letter-spacing: 0.02em;
}
.header-sep { width: 1px; height: 20px; background: rgba(255,255,255,0.2); }
.header-title {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.75rem;
  color: rgba(255,255,255,0.5);
  letter-spacing: 0.12em;
  text-transform: uppercase;
}
.header-right { display: flex; align-items: center; gap: 1.5rem; }
.mastery-pill {
  display: flex; align-items: center; gap: 0.5rem;
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 20px;
  padding: 0.3rem 0.9rem;
}
.mastery-label { font-size: 0.65rem; color: rgba(255,255,255,0.45); text-transform: uppercase; letter-spacing: 0.1em; }
.mastery-val { font-size: 0.9rem; font-weight: 600; color: var(--crimson-light); }
.nav-toggle {
  background: none; border: none; cursor: pointer;
  display: flex; flex-direction: column; gap: 5px; padding: 4px;
}
.nav-toggle span { display: block; width: 22px; height: 2px; background: rgba(255,255,255,0.6); border-radius: 2px; transition: 0.3s; }
 
/* ── SIDE DRAWER NAV ─────────────────────────── */
.drawer {
  position: fixed; top: 60px; right: 0; bottom: 0; z-index: 90;
  width: 280px;
  background: var(--navy);
  transform: translateX(100%);
  transition: transform 0.35s cubic-bezier(0.4,0,0.2,1);
  overflow-y: auto;
  padding: 2rem 1.5rem;
  box-shadow: -8px 0 32px rgba(0,0,0,0.3);
}
.drawer.open { transform: translateX(0); }
.drawer-title { font-size: 0.65rem; color: rgba(255,255,255,0.35); text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 1.5rem; }
.nav-item {
  display: flex; align-items: center; gap: 0.75rem;
  padding: 0.75rem 1rem;
  border-radius: 10px;
  cursor: pointer;
  transition: background 0.2s;
  margin-bottom: 0.25rem;
  text-decoration: none;
  color: rgba(255,255,255,0.6);
  font-size: 0.85rem;
  user-select: none;
}
.nav-item:hover { background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.9); }
.nav-item.active { background: rgba(192,48,63,0.2); color: var(--crimson-light); }
.nav-dot {
  width: 22px; height: 22px; border-radius: 50%;
  border: 2px solid rgba(255,255,255,0.2);
  display: flex; align-items: center; justify-content: center;
  font-size: 0.65rem; font-weight: 700; flex-shrink: 0;
  color: rgba(255,255,255,0.4);
}
.nav-item.done .nav-dot { background: var(--crimson); border-color: var(--crimson); color: white; }
.nav-item.active .nav-dot { border-color: var(--crimson-light); color: var(--crimson-light); }
 
/* ── OVERLAY ─────────────────────────────────── */
.overlay { position: fixed; inset: 0; z-index: 80; background: rgba(0,0,0,0.4); opacity: 0; pointer-events: none; transition: opacity 0.3s; }
.overlay.show { opacity: 1; pointer-events: all; }
 
/* ── HERO ────────────────────────────────────── */
.hero {
  min-height: 100vh;
  background: var(--navy);
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: 6rem 2rem 4rem;
  position: relative;
  overflow: hidden;
}
.hero::before {
  content: ''; position: absolute; inset: 0;
  background: radial-gradient(ellipse 80% 60% at 50% 40%, rgba(192,48,63,0.12) 0%, transparent 70%);
  pointer-events: none;
}
.hero-eyebrow {
  font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase;
  color: var(--crimson-light); margin-bottom: 1.5rem;
  display: flex; align-items: center; gap: 0.75rem;
}
.hero-eyebrow::before, .hero-eyebrow::after {
  content: ''; display: block; width: 30px; height: 1px; background: var(--crimson);
}
.hero-title {
  font-family: 'Playfair Display', serif;
  font-style: italic;
  font-size: clamp(3rem, 8vw, 6rem);
  color: var(--white);
  line-height: 1.1;
  text-align: center;
  margin-bottom: 1rem;
  position: relative;
}
.hero-title span { color: var(--crimson-light); }
.hero-subtitle {
  font-family: 'Crimson Pro', serif;
  font-size: 1.25rem;
  color: rgba(255,255,255,0.55);
  text-align: center;
  max-width: 520px;
  line-height: 1.6;
  margin-bottom: 3rem;
}
.hero-modules {
  display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center;
  margin-bottom: 3rem;
}
.module-chip {
  display: flex; align-items: center; gap: 0.5rem;
  background: rgba(255,255,255,0.07);
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 30px;
  padding: 0.4rem 1rem;
  font-size: 0.78rem; color: rgba(255,255,255,0.6);
  cursor: pointer; transition: all 0.2s;
}
.module-chip:hover {
  background: rgba(192,48,63,0.25);
  border-color: var(--crimson-light);
  color: var(--white);
  transform: translateY(-2px);
}
.module-chip-num { color: var(--crimson-light); font-weight: 600; }
.hero-cta {
  background: var(--crimson);
  color: white;
  border: none; cursor: pointer;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.9rem; font-weight: 600;
  padding: 1rem 2.5rem;
  border-radius: 50px;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  transition: all 0.3s;
  box-shadow: 0 8px 32px rgba(192,48,63,0.4);
}
.hero-cta:hover { background: var(--crimson-light); transform: translateY(-2px); box-shadow: 0 12px 40px rgba(192,48,63,0.5); }
.hero-eyebrow,
.hero-title,
.hero-subtitle,
.hero-modules,
.hero-cta,
.hero-scroll { position: relative; z-index: 1; }
.hero-scroll::after { content: '↓'; font-size: 1.2rem; }
@keyframes float { 0%, 100% { transform: translateX(-50%) translateY(0); } 50% { transform: translateX(-50%) translateY(6px); } }
 
/* ── CONTENT WRAPPER ─────────────────────────── */
.content { padding-top: 60px; }
 
/* ── SECTION HEADER ──────────────────────────── */
.section-intro {
  background: var(--cream-dark);
  padding: 4rem 2rem;
  text-align: center;
  border-bottom: 1px solid var(--border);
}
.section-intro .module-tag {
  font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase;
  color: var(--crimson); margin-bottom: 0.75rem; display: block;
}
.section-intro h2 {
  font-family: 'Playfair Display', serif;
  font-style: italic;
  font-size: clamp(2rem, 5vw, 3.5rem);
  color: var(--navy);
  margin-bottom: 0.75rem;
}
.section-intro .meta {
  display: flex; align-items: center; justify-content: center; gap: 2rem;
  font-size: 0.78rem; color: var(--text-light); margin-top: 0.75rem;
}
.section-intro .meta span { display: flex; align-items: center; gap: 0.35rem; }
 
/* ── MODULE CONTAINER ────────────────────────── */
.module-section {
  max-width: 820px; margin: 0 auto;
  padding: 3rem 2rem 4rem;
}
 
/* ── THEORY CARD ─────────────────────────────── */
.theory-intro {
  font-family: 'Crimson Pro', serif;
  font-size: 1.2rem;
  color: var(--navy-mid);
  line-height: 1.75;
  border-left: 3px solid var(--crimson);
  padding-left: 1.25rem;
  margin-bottom: 2.5rem;
}
 
.theory-grid { display: grid; gap: 1.25rem; margin-bottom: 2.5rem; }
.theory-card {
  background: var(--white);
  border-radius: 16px;
  padding: 1.5rem 1.75rem;
  box-shadow: var(--shadow);
  border: 1px solid var(--border);
  display: flex; gap: 1.25rem; align-items: flex-start;
}
.theory-icon {
  width: 42px; height: 42px; border-radius: 12px;
  background: var(--rose);
  display: flex; align-items: center; justify-content: center;
  font-size: 1.1rem; flex-shrink: 0;
}
.theory-card h4 {
  font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.1em;
  color: var(--crimson); margin-bottom: 0.35rem; font-weight: 600;
}
.theory-card p { font-size: 0.92rem; color: var(--text); line-height: 1.6; }
 
/* ── SECTION DIVIDER ─────────────────────────── */
.section-divider {
  display: flex; align-items: center; gap: 1rem;
  margin: 2.5rem 0 1.75rem;
}
.section-divider::before, .section-divider::after {
  content: ''; flex: 1; height: 1px; background: var(--border);
}
.section-divider span {
  font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase;
  color: var(--text-light); white-space: nowrap;
}
 
/* ── INTERACTIVE LAB ─────────────────────────── */
.lab-box {
  background: var(--navy);
  border-radius: 20px;
  padding: 2rem;
  margin-bottom: 2rem;
  position: relative;
  overflow: hidden;
}
.lab-box::before {
  content: 'LAB EXERCISE';
  position: absolute; top: 1.25rem; left: 1.75rem;
  font-size: 0.6rem; letter-spacing: 0.2em; color: var(--crimson-light);
  font-weight: 600;
}
.lab-box h3 {
  font-family: 'Playfair Display', serif;
  font-size: 1.3rem; color: var(--white);
  margin-top: 1.5rem; margin-bottom: 0.5rem;
}
.lab-box p { font-size: 0.88rem; color: rgba(255,255,255,0.55); line-height: 1.6; margin-bottom: 1.5rem; }
 
/* ── BREATHING EXERCISE ──────────────────────── */
.breathing-wrap { display: flex; flex-direction: column; align-items: center; padding: 1rem 0; }
.breath-ring {
  width: 160px; height: 160px; border-radius: 50%;
  border: 3px solid rgba(192,48,63,0.3);
  display: flex; align-items: center; justify-content: center;
  position: relative; margin-bottom: 1.5rem;
  transition: all 0.8s cubic-bezier(0.4,0,0.2,1);
}
.breath-ring.inhale { transform: scale(1.35); border-color: rgba(192,48,63,0.8); box-shadow: 0 0 40px rgba(192,48,63,0.3); }
.breath-ring.hold { transform: scale(1.35); border-color: rgba(201,151,58,0.8); box-shadow: 0 0 40px rgba(201,151,58,0.3); }
.breath-ring.exhale { transform: scale(1); border-color: rgba(45,122,79,0.8); box-shadow: 0 0 40px rgba(45,122,79,0.2); }
.breath-ring.hold2 { transform: scale(1); border-color: rgba(192,48,63,0.3); }
.breath-inner {
  width: 120px; height: 120px; border-radius: 50%;
  background: radial-gradient(circle, rgba(192,48,63,0.15), rgba(192,48,63,0.05));
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  gap: 0.25rem;
}
.breath-phase { font-size: 0.8rem; font-weight: 600; letter-spacing: 0.08em; color: var(--crimson-light); text-transform: uppercase; }
.breath-count { font-family: 'Playfair Display', serif; font-size: 2rem; color: var(--white); }
.breath-timer { font-size: 0.75rem; color: rgba(255,255,255,0.4); }
.breath-controls { display: flex; gap: 1rem; }
.btn-lab {
  background: var(--crimson); color: white; border: none; cursor: pointer;
  font-family: 'DM Sans', sans-serif; font-size: 0.82rem; font-weight: 600;
  padding: 0.65rem 1.5rem; border-radius: 30px; transition: all 0.2s;
  letter-spacing: 0.05em; text-transform: uppercase;
}
.btn-lab:hover { background: var(--crimson-light); }
.btn-lab.secondary {
  background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15);
}
.btn-lab.secondary:hover { background: rgba(255,255,255,0.15); }
.breath-cycles { font-size: 0.78rem; color: rgba(255,255,255,0.4); margin-top: 0.75rem; }
 
/* ── CHECKLIST ───────────────────────────────── */
.lab-checklist { display: flex; flex-direction: column; gap: 0.75rem; }
.check-item {
  display: flex; align-items: center; gap: 0.85rem;
  background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);
  border-radius: 12px; padding: 0.85rem 1rem;
  cursor: pointer; transition: all 0.2s;
  color: rgba(255,255,255,0.7); font-size: 0.88rem;
}
.check-item:hover { background: rgba(255,255,255,0.1); }
.check-item.checked { background: rgba(192,48,63,0.15); border-color: rgba(192,48,63,0.4); color: white; }
.check-box {
  width: 22px; height: 22px; border-radius: 6px;
  border: 2px solid rgba(255,255,255,0.25); flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  font-size: 0.75rem; transition: all 0.2s;
}
.check-item.checked .check-box { background: var(--crimson); border-color: var(--crimson); color: white; }
 
/* ── TONGUE TWISTERS ─────────────────────────── */
.twister-card {
  background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);
  border-radius: 14px; padding: 1.25rem 1.5rem; margin-bottom: 0.75rem;
  cursor: pointer; transition: all 0.2s; color: var(--white);
}
.twister-card:hover { background: rgba(255,255,255,0.1); }
.twister-card.active { border-color: var(--crimson); background: rgba(192,48,63,0.12); }
.twister-text { font-family: 'Crimson Pro', serif; font-size: 1.1rem; line-height: 1.5; }
.twister-label { font-size: 0.68rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--crimson-light); margin-bottom: 0.35rem; }
.pace-timer-display {
  text-align: center; padding: 1.5rem 0;
  font-family: 'Playfair Display', serif; font-size: 3.5rem;
  color: var(--white); line-height: 1;
}
.pace-phase-label { font-size: 0.8rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--crimson-light); margin-bottom: 0.5rem; }
 
/* ── INDEX CARD ──────────────────────────────── */
.index-card-builder { display: flex; flex-direction: column; gap: 1rem; }
.ic-field label { display: block; font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--crimson-light); margin-bottom: 0.4rem; }
.ic-field input {
  width: 100%; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15);
  border-radius: 10px; padding: 0.75rem 1rem;
  color: white; font-family: 'DM Sans', sans-serif; font-size: 0.9rem;
  outline: none; transition: border-color 0.2s;
}
.ic-field input:focus { border-color: var(--crimson); }
.ic-field input::placeholder { color: rgba(255,255,255,0.25); }
.ic-preview {
  background: var(--cream-dark); border-radius: 12px; padding: 1.25rem;
  border: 2px dashed rgba(13,27,42,0.15); margin-top: 0.5rem;
}
.ic-preview-title { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--text-light); margin-bottom: 0.75rem; }
.ic-preview-point { display: flex; gap: 0.75rem; padding: 0.5rem 0; font-size: 0.9rem; color: var(--navy); border-bottom: 1px dashed var(--border); }
.ic-preview-point:last-child { border-bottom: none; }
.ic-num { width: 22px; height: 22px; border-radius: 50%; background: var(--crimson); color: white; font-size: 0.7rem; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 1px; }
 
/* ── QUIZ ────────────────────────────────────── */
.quiz-wrap {
  background: var(--white);
  border-radius: 20px;
  padding: 2rem;
  box-shadow: var(--shadow);
  border: 1px solid var(--border);
  margin-bottom: 2rem;
}
.quiz-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; }
.quiz-tag { font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--crimson); font-weight: 600; }
.quiz-progress-dots { display: flex; gap: 0.35rem; }
.q-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--border); transition: all 0.3s; }
.q-dot.active { background: var(--crimson); transform: scale(1.2); }
.q-dot.done { background: var(--green); }
.quiz-q {
  font-family: 'Crimson Pro', serif;
  font-size: 1.25rem; color: var(--navy);
  line-height: 1.5; margin-bottom: 1.25rem;
}
.quiz-options { display: flex; flex-direction: column; gap: 0.6rem; }
.q-opt {
  display: flex; align-items: center; gap: 0.75rem;
  padding: 0.85rem 1.1rem;
  border-radius: 12px;
  border: 1.5px solid var(--border);
  cursor: pointer; transition: all 0.2s;
  font-size: 0.9rem; color: var(--text);
}
.q-opt:hover { border-color: var(--crimson); background: var(--rose); }
.q-opt.correct { background: #e8f7ef; border-color: var(--green); color: var(--green); }
.q-opt.wrong { background: #fef2f3; border-color: var(--crimson); color: var(--crimson); }
.q-opt.disabled { cursor: default; pointer-events: none; }
.q-opt-letter {
  width: 26px; height: 26px; border-radius: 50%;
  background: var(--border); display: flex; align-items: center; justify-content: center;
  font-size: 0.75rem; font-weight: 700; flex-shrink: 0;
  transition: all 0.2s;
}
.q-opt.correct .q-opt-letter { background: var(--green); color: white; }
.q-opt.wrong .q-opt-letter { background: var(--crimson); color: white; }
.quiz-feedback {
  margin-top: 1rem; padding: 0.9rem 1.1rem;
  border-radius: 12px; font-size: 0.88rem; line-height: 1.5;
  display: none;
}
.quiz-feedback.show { display: block; animation: fadeIn 0.3s ease; }
.quiz-feedback.correct { background: #e8f7ef; color: var(--green); border-left: 3px solid var(--green); }
.quiz-feedback.wrong { background: #fef2f3; color: #a02030; border-left: 3px solid var(--crimson); }
.quiz-nav { display: flex; justify-content: space-between; align-items: center; margin-top: 1.25rem; }
.btn-quiz-next {
  background: var(--navy); color: white; border: none; cursor: pointer;
  font-family: 'DM Sans', sans-serif; font-size: 0.82rem; font-weight: 600;
  padding: 0.65rem 1.5rem; border-radius: 30px; transition: all 0.2s;
  letter-spacing: 0.05em; opacity: 0; pointer-events: none;
}
.btn-quiz-next.show { opacity: 1; pointer-events: all; }
.btn-quiz-next:hover { background: var(--crimson); }
.quiz-score { font-size: 0.8rem; color: var(--text-light); }
.quiz-result {
  text-align: center; padding: 2rem 1rem;
}
.result-score {
  font-family: 'Playfair Display', serif;
  font-style: italic; font-size: 3.5rem; color: var(--navy);
  line-height: 1; margin-bottom: 0.5rem;
}
.result-label { font-size: 0.85rem; color: var(--text-light); margin-bottom: 1.5rem; }
.result-msg { font-family: 'Crimson Pro', serif; font-size: 1.1rem; color: var(--navy-mid); line-height: 1.5; }
 
/* ── REFLECTION ──────────────────────────────── */
.reflection-wrap {
  background: var(--cream-dark);
  border-radius: 20px;
  padding: 2rem;
  margin-bottom: 2rem;
  border: 1px solid var(--border);
}
.reflection-quote {
  font-family: 'Playfair Display', serif;
  font-style: italic;
  font-size: 1.15rem; color: var(--navy);
  line-height: 1.6; margin-bottom: 1.25rem;
  border-left: 3px solid var(--crimson);
  padding-left: 1rem;
}
.reflection-label { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.15em; color: var(--text-light); margin-bottom: 0.5rem; display: block; }
.reflection-wrap textarea {
  width: 100%; min-height: 110px;
  background: var(--white); border: 1.5px solid var(--border);
  border-radius: 12px; padding: 1rem;
  font-family: 'Crimson Pro', serif; font-size: 1rem;
  color: var(--text); resize: vertical; outline: none;
  transition: border-color 0.2s; line-height: 1.6;
}
.reflection-wrap textarea:focus { border-color: var(--crimson); }
.reflection-wrap textarea::placeholder { color: #b0b8c4; }
