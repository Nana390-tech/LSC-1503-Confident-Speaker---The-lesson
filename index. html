window.addEventListener('DOMContentLoaded', ()=>{
  // Restore name if previously entered
  const saved = localStorage.getItem('studentName');
  if(saved){ document.getElementById('studentName').value=saved; }
 
  // Restore badges
  [1,2,3,4].forEach(n=>{
